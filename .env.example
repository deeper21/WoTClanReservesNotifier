# Telegram Bot Token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Wargaming Application ID (from https://developers.wargaming.net/applications/)
WG_APPLICATION_ID=your-wg-application-id

# Public URL where this bot is reachable (no trailing slash)
# On Railway this is automatically set, or use your custom domain
PUBLIC_URL=https://your-app.up.railway.app

# Port for the auth callback web server (Railway sets this automatically)
PORT=8080

# SQLite database file path
DATABASE_PATH=bot_data.db

# Reserve polling interval in seconds (default: 60)
POLL_INTERVAL=60

# Token expiry warning threshold in seconds (default: 86400 = 24h)
TOKEN_EXPIRY_WARNING=86400

# Encryption key for access tokens at rest (any string, used to derive Fernet key)
# IMPORTANT: set this in production! If not set, a random key file is auto-generated.
ENCRYPTION_KEY=change-me-to-a-random-secret-string
